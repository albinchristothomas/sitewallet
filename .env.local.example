# Supabase project URL and anon key. Copy from your project's API settings.
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only secret. Used to mint shadow auth users for
# medic walk-ins. NEVER prefix with NEXT_PUBLIC and never expose to the client.
# Same page: Project Settings → API → service_role (secret) key.
SUPABASE_SERVICE_ROLE_KEY=
